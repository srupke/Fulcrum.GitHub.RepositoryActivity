{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Repository Activity (Mock)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:mock"],
      "serverReadyAction": {
        "pattern": "ready in",
        "uriFormat": "http://localhost:3000/",
        "action": "openExternally"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Repository Activity (Live — requires .env.local)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "serverReadyAction": {
        "pattern": "ready in",
        "uriFormat": "http://localhost:3000/",
        "action": "openExternally"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
