# Copy this file to .env.local and fill in values from the stack outputs.
# .env.local is gitignored — never commit real credentials.

# Set VITE_MOCK=true to run with mock data (no AWS required)
# Set VITE_MOCK=false (or omit) to use the real deployed API
VITE_MOCK=false

# Cognito — from stack output UserPoolId
VITE_USER_POOL_ID=us-east-1_XXXXXXXXX

# Cognito — from stack output UserPoolClientId
VITE_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Cognito — from stack output CognitoDomain
VITE_COGNITO_DOMAIN=fulcrum-github-repo-activity-123456789012.auth.us-east-1.amazoncognito.com

# API Gateway — from stack output ApiEndpoint (used as Vite dev proxy target)
VITE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com
